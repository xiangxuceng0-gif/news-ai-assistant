# Anthropic API Key (用于 AI 摘要)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# 飞书/Lark Bot Webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxxxxx

# 可选: AI 模型选择 (默认 claude-haiku-4-5-20251001，成本低效果好)
# 也可用 claude-sonnet-4-6-20250514 获得更高质量摘要
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# 可选: 每日推送时间偏好 (仅用于日志展示，实际定时由 GitHub Actions 控制)
REPORT_TIME=08:00

# 可选: 最大新闻条数 (默认 20)
MAX_NEWS_COUNT=20
